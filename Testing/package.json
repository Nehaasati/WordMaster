{
  "name": "testing",
  "version": "1.0.0",
  "description": "",
  "type": "module",
  "scripts": {
    "test": "npm run test:ui",
    "bdd:gen": "npx bddgen",
    "test:ui": "npm run bdd:gen; npx playwright test --ui",
    "test:headed": "npm run bdd:gen && playwright test --project=ui --headed",
    "test:debug": "npm run bdd:gen && playwright test --project=ui --debug",
    "report": "playwright show-report"
  },
  "devDependencies": {
    "@playwright/test": "^1.59.1",
    "playwright-bdd": "^8.5.0"
  }
}