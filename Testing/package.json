{
  "name": "testing",
  "version": "1.0.0",
  "description": "",
  "type": "module",
  "scripts": {
    "bdd:gen": "bddgen",
    "test": "npm run test:unit && npm run test:api && npm run test:ui",
    "test:api": "newman run Postman/WordMasterApi.postman_collection.json -e Postman/WordMasterAPI-Env.postman_environment.json --reporters cli",
    "test:api:ci": "newman run Postman/WordMasterApi.postman_collection.json -e Postman/WordMasterAPI-Env.postman_environment.json --reporters cli,junit --reporter-junit-export test-results/newman-api.xml",
    "test:ui": "npm run bdd:gen && npx playwright test --project=ui",
    "test:unit": "dotnet test ../UnitTests/WordMaster.UnitTests/WordMaster.UnitTests.csproj",
    "test:headed": "npm run bdd:gen && playwright test --project=ui --headed",
    "codegen": "playwright codegen http://127.0.0.1:5024",
    "test:perf:load": "k6 run --env TEST_PROFILE=load k6/wordmaster-multiplayer.js",
    "test:perf:stress": "k6 run --env TEST_PROFILE=stress k6/wordmaster-multiplayer.js",
    "test:security:multiplayer": "node security/multiplayer-abuse.js"
  },
  "devDependencies": {
    "@playwright/test": "^1.59.1"
  },
  "dependencies": {
    "playwright-bdd": "^8.4.1"
  }
}
