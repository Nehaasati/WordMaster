         {
          "name": "ugglanTest",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test(\"Status code is 200\", function () {\r",
                  "    pm.response.to.have.status(200);\r",
                  "});\r",
                  "\r",
                  "pm.test(\"Correct character returned\", function () {\r",
                  "    var jsonData = pm.response.json();\r",
                  "\r",
                  "    pm.expect(jsonData.id).to.eql(\"ugglan\");\r",
                  "    pm.expect(jsonData.name).to.eql(\"Ugglan\");\r",
                  "});\r",
                  "\r",
                  "pm.test(\"Check required fields exist\", function () {\r",
                  "    var jsonData = pm.response.json();\r",
                  "\r",
                  "    pm.expect(jsonData).to.have.all.keys(\"id\",\"name\",\"description\",\"ability\");\r",
                  "    pm.expect(jsonData.ability).to.have.property(\"type\");\r",
                  "});"
                ],
                "type": "text/javascript",
                "packages": {},
                "requests": {}
              }
            }
          ],
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{base_url}}/character/ugglan",
              "host": [
                "{{base_url}}"
              ],
              "path": [
                "character",
                "ugglan"
              ]
            }
          },
          "response": []
        },
        {
          "name": "ApiCharacter",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test(\"Status code is 200\", function () {\r",
                  "    pm.response.to.have.status(200);\r",
                  "});\r",
                  "\r",
                  "pm.test(\"Response is an array\", function () {\r",
                  "    var jsonData = pm.response.json();\r",
                  "    pm.expect(jsonData).to.be.an(\"array\");\r",
                  "});\r",
                  "\r",
                  "pm.test(\"Array is not empty\", function () {\r",
                  "    var jsonData = pm.response.json();\r",
                  "    pm.expect(jsonData.length).to.be.above(0);\r",
                  "});\r",
                  "\r",
                  "pm.test(\"Each character has required fields\", function () {\r",
                  "    var jsonData = pm.response.json();\r",
                  "\r",
                  "    jsonData.forEach(character => {\r",
                  "        pm.expect(character).to.have.all.keys(\"id\", \"name\", \"description\", \"ability\");\r",
                  "        pm.expect(character.ability).to.have.property(\"type\");\r",
                  "    });\r",
                  "});"
                ],
