      "name": "LobbyApi",
      "item": [
        {
          "name": "Create Lobby",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test(\"Status is 200\", () => {\r",
                  "    pm.response.to.have.status(200);\r",
                  "});\r",
                  "\r",
                  "const json = pm.response.json();\r",
                  "\r",
                  "pm.collectionVariables.set(\"lobbyId\", json.lobbyId);\r",
                  "pm.collectionVariables.set(\"inviteCode\", json.inviteCode);\r",
                  "\r",
                  "pm.test(\"Lobby ID and Invite Code exist\", () => {\r",
                  "    pm.expect(json.lobbyId).to.be.a(\"string\");\r",
                  "    pm.expect(json.inviteCode).to.be.a(\"string\");\r",
                  "});"
                ],
                "type": "text/javascript",
                "packages": {},
                "requests": {}
              }
            }
