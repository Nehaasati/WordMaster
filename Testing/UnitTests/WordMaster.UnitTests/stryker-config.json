{
  "stryker-config": {
    "solution": "../../../backend.sln",
    "project": "backend.csproj",
    "target-framework": "net10.0",
    "mutation-level": "Basic",
    "coverage-analysis": "perTest",
    "reporters": [
      "progress",
      "html",
      "json"
